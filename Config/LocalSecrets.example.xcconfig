// Copy to Config/LocalSecrets.xcconfig and fill in your real values.
// GitHub Actions release builds can inject the same values from repository secrets.
// xcconfig treats `//` as the start of a comment, so build URLs via a slash helper.

_XC_SLASH = /
SPARKLE_APPCAST_URL = https:$(_XC_SLASH)/example.com/appcast.xml
SPARKLE_PUBLIC_ED_KEY = REPLACE_WITH_SPARKLE_PUBLIC_ED_KEY

// Optional anonymous product telemetry upload target.
// Use the SLS region endpoint host only, for example: ap-southeast-1.log.aliyuncs.com
// Project and Logstore default to ping-island-global / ping-island from Config/App.xcconfig.
PING_ISLAND_TELEMETRY_SLS_HOST =
